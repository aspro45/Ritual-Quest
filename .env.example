# Ritual ProofGraph
# Copy to .env and fill locally. Never commit private keys or OAuth secrets.

RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_CHAIN_ID=1979
DEPLOYER_PRIVATE_KEY=
# Dedicated testnet wallet used by the role-gated review API. If omitted locally,
# DEPLOYER_PRIVATE_KEY is used as a compatibility fallback.
REVIEW_RELAYER_PRIVATE_KEY=
INITIAL_ATTESTOR=

VITE_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
VITE_RITUAL_CHAIN_ID=1979
VITE_PROOFGRAPH_ADDRESS=
VITE_REVIEW_DECISIONS_ADDRESS=
VITE_REVIEW_DECISIONS_START_BLOCK=0
# Keep direct registry writes disabled after the coordinator is configured.
REVOKE_DIRECT_REGISTRY_ATTESTOR=true

# OAuth verification backend. Never expose client secrets through VITE_*.
APP_BASE_URL=http://127.0.0.1:5192
OAUTH_STATE_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:5192/api/oauth?action=callback&provider=discord
DISCORD_GUILD_ID=
DISCORD_REQUIRED_ROLE_ID=
DISCORD_REQUIRED_ROLE_IDS=
# Discord roles allowed to see the reviewer console. Use comma-separated role IDs.
# The same wallet must also be an attestor on ProofReviewDecisions.
DISCORD_ATTESTOR_ROLE_ID=
DISCORD_ATTESTOR_ROLE_IDS=

# Shared website calendar. No Discord bot is needed.
# Create the calendar_events table from README, then set these server-only values.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Discord roles allowed to create events in the website calendar.
DISCORD_EVENT_MANAGER_ROLE_IDS=
# Optional verified wallets allowed to create events. Separate multiple addresses with commas.
DISCORD_EVENT_MANAGER_WALLETS=
# Discord roles allowed to publish campaigns from the Explore page.
DISCORD_CAMPAIGN_MANAGER_ROLE_IDS=
# Wallets allowed to publish after Discord OAuth verifies a wallet signature.
DISCORD_CAMPAIGN_MANAGER_WALLETS=

# Optional: first block where ProofGraphRegistry was deployed. Set this after deployment
# to keep review-event scans fast while retaining a fully onchain review queue.
VITE_PROOFGRAPH_REVIEW_START_BLOCK=0

# X is kept as public evidence links in the app, so these are not required.
# Leave empty unless you later decide to re-enable paid X API verification.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:5192/api/oauth?action=callback&provider=x
X_TARGET_USER_ID=
X_TARGET_TWEET_ID=
